# API Configuration
# For local development, use localhost
# For network access from other devices, replace localhost with your machine's IP address
# Example: VITE_API_BASE_URL=http://192.168.1.100/api

# IMPORTANT: After changing this value, restart the dev server (npm run dev)
# Images will be loaded from: {VITE_API_BASE_URL}/uploads/...

VITE_API_BASE_URL=http://localhost/api
